<UserControl x:Class="PSVCalc.App.Features.Inputs.InputPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:inputs="clr-namespace:PSVCalc.App.Features.Inputs"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Margin="0,0,12,0">
                    <Border Style="{DynamicResource CardBorder}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Loc[inputs]}" Style="{DynamicResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding Loc[input_panel_hint]}"
                                               Style="{DynamicResource SectionHintStyle}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource BrushAccentPanelBackground}"
                                        BorderBrush="{DynamicResource BrushAccentPanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource ThemeCornerRadiusControl}"
                                        Padding="10,4"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Loc[scenario]}"
                                               Foreground="{DynamicResource BrushReportPillText}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
    
                            <TabControl SelectedIndex="{Binding SelectedScenarioTabIndex}"
                                        Margin="0,0,0,14"
                                        Style="{DynamicResource LargeTabControlStyle}"
                                        ItemContainerStyle="{DynamicResource LargeTabItemStyle}">
                                <TabItem Header="{Binding Loc[scenario_overpressure]}" />
                                <TabItem Header="{Binding Loc[scenario_fire]}" />
                                <TabItem Header="{Binding Loc[scenario_tube_rupture]}" />
                                <TabItem Header="{Binding Loc[scenario_thermal_expansion]}" />
                            </TabControl>
    
                            <Border Style="{DynamicResource SnapshotHeroStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="216" />
                                    </Grid.ColumnDefinitions>
    
                                    <StackPanel>
                                        <TextBlock Text="{Binding Loc[design_snapshot_title]}"
                                                   Style="{DynamicResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding Loc[design_snapshot_hint]}"
                                                   Style="{DynamicResource SectionHintStyle}"
                                                   Margin="0,6,0,0" />
    
                                        <UniformGrid Columns="2"
                                                     Margin="0,12,0,0">
                                            <Border Style="{DynamicResource SnapshotMiniCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Loc[fluid_type]}" Style="{DynamicResource FieldLabelStyle}" />
                                                    <TextBlock Text="{Binding CurrentFluidLabel}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrushTextMain}" />
                                                </StackPanel>
                                            </Border>
    
                                            <Border Style="{DynamicResource SnapshotMiniCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Loc[scenario]}" Style="{DynamicResource FieldLabelStyle}" />
                                                    <TextBlock Text="{Binding CurrentScenarioLabel}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrushTextMain}" />
                                                </StackPanel>
                                            </Border>
    
                                            <Border Style="{DynamicResource SnapshotMiniCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Loc[pressure_mode]}" Style="{DynamicResource FieldLabelStyle}" />
                                                    <TextBlock Text="{Binding CurrentPressureModeLabel}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrushTextMain}" />
                                                </StackPanel>
                                            </Border>
    
                                            <Border Style="{DynamicResource SnapshotMiniCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Loc[use_operating_pressure_basis]}" Style="{DynamicResource FieldLabelStyle}" />
                                                    <TextBlock Text="{Binding CurrentPressureBasisLabel}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrushTextMain}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
    
                                    <Border Grid.Column="1"
                                            Style="{DynamicResource SnapshotAsideStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Loc[standard_version]}"
                                                       Foreground="{DynamicResource BrushTextOnPrimaryMuted}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CurrentStandardLabel}"
                                                       Foreground="{DynamicResource BrushTextOnPrimary}"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap" />
    
                                            <Separator Margin="0,14,0,14"
                                                       Background="{DynamicResource BrushAccentPanelDivider}" />
    
                                            <TextBlock Text="{Binding Loc[view_mode]}"
                                                       Foreground="{DynamicResource BrushTextOnPrimaryMuted}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CurrentViewModeLabel}"
                                                       Foreground="{DynamicResource BrushTextOnPrimary}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Margin="0,8,0,0" />
    
                                            <TextBlock Text="{Binding Loc[valve_configuration]}"
                                                       Foreground="{DynamicResource BrushTextOnPrimaryMuted}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Margin="0,18,0,0" />
                                            <TextBlock Text="{Binding CurrentValveConfigurationLabel}"
                                                       Foreground="{DynamicResource BrushTextOnPrimary}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap" />
    
                                            <TextBlock Text="{Binding Loc[pressure_unit]}"
                                                       Foreground="{DynamicResource BrushTextOnPrimaryMuted}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Margin="0,18,0,0" />
                                            <TextBlock Text="{Binding PressureUnit}"
                                                       Foreground="{DynamicResource BrushTextOnPrimary}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Margin="0,8,0,0" />
    
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
    
                            <TabControl Style="{DynamicResource LargeTabControlStyle}"
                                        ItemContainerStyle="{DynamicResource LargeTabItemStyle}">
                                <TabItem Header="{Binding Loc[input_tab_overview]}">
                                    <inputs:OverviewInputTab />
                                </TabItem>

                                <TabItem Header="{Binding Loc[input_tab_pressure_load]}">
                                    <inputs:PressureLoadInputTab />
                                </TabItem>

                                <TabItem Header="{Binding Loc[input_tab_fluid_coeff]}">
                                    <inputs:FluidCoefficientsInputTab />
                                </TabItem>

                                <TabItem Header="{Binding Loc[input_tab_scenario_detail]}">
                                    <inputs:ScenarioDetailsInputTab />
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                    </Border>
    </ScrollViewer>
</UserControl>

