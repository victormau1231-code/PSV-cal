<UserControl x:Class="PSVCalc.App.Features.Expert.ExpertPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <StackPanel>
        <Border Style="{DynamicResource CardBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Loc[expert_title]}" Style="{DynamicResource SectionTitleStyle}" />
                    <TextBlock Text="{Binding Loc[expert_panel_hint]}"
                               Style="{DynamicResource SectionHintStyle}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="{DynamicResource BrushAccentPanelBackground}"
                        BorderBrush="{DynamicResource BrushAccentPanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource ThemeCornerRadiusControl}"
                        Padding="10,4"
                        VerticalAlignment="Center">
                    <TextBlock Text="Audit Mode"
                               Foreground="{DynamicResource BrushReportPillText}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Style="{DynamicResource CardBorder}">
            <Border Style="{DynamicResource GridCardStyle}">
                <DataGrid ItemsSource="{Binding ExpertRows}"
                          Style="{DynamicResource ModernDataGrid}"
                          AutoGenerateColumns="False"
                          MinHeight="220"
                          MaxHeight="320"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Parameter" Binding="{Binding Parameter}" Width="1.2*" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                        <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="110" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>
    </StackPanel>
</UserControl>
