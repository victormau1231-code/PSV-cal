<Window x:Class="PSVCalc.App.Views.PilotOperatedSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Loc[pilot_settings_title], FallbackValue=Pilot-Operated Valve Settings}"
        Width="720"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="680"
        MinHeight="560"
        Background="{DynamicResource BrushWindowBackground}"
        FontFamily="{DynamicResource AppFontFamily}"
        FontSize="13">
    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BrushCardBackground}" />
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeCornerRadiusCard}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushCardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Effect" Value="{DynamicResource ThemeCardEffect}" />
        </Style>

        <Style x:Key="HeroCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="Background" Value="{DynamicResource BrushHeaderBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushHeaderBorder}" />
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeCornerRadiusLarge}" />
        </Style>

        <Style x:Key="FieldBorder" TargetType="Border">
            <Setter Property="Width" Value="210" />
            <Setter Property="Background" Value="{DynamicResource BrushOverviewFieldBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushCardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeCornerRadiusLarge}" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BrushFieldLabel}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextMain}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BrushInputBackgroundElevated}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorderFocus}" />
                    <Setter Property="Background" Value="{DynamicResource BrushCardBackground}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextMain}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource ThemeCornerRadiusSmall}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushComboItemHover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource BrushComboItemSelected}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushComboItemSelectedForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextMain}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BrushInputBackgroundElevated}" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource InputComboBoxItemStyle}" />
            <Setter Property="MaxDropDownHeight" Value="320" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorderFocus}" />
                    <Setter Property="Background" Value="{DynamicResource BrushCardBackground}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextMain}" />
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushActionBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BrushActionBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushActionForeground}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ThemeCornerRadiusControl}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushActionHoverBackground}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BrushActionHoverBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource BrushActionPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{DynamicResource BrushPrimaryActionBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushPrimaryActionBorder}" />
            <Setter Property="Foreground" Value="{DynamicResource BrushPrimaryActionForeground}" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroCardStyle}">
            <StackPanel>
                <TextBlock Text="{Binding Loc[pilot_settings_title]}"
                           Foreground="{DynamicResource BrushTextOnPrimary}"
                           FontSize="18"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding Loc[pilot_settings_hint]}"
                           Foreground="{DynamicResource BrushTextOnPrimaryMuted}"
                           Margin="0,6,0,0"
                           FontSize="13"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}">
                    <WrapPanel>
                        <Border Style="{StaticResource FieldBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[pilot_min_operating_differential_percent]}" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="MinimumDifferentialTextBox" Style="{StaticResource InputTextBox}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource FieldBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[pilot_sense_line_mode]}" Style="{StaticResource FieldLabel}" />
                                <ComboBox x:Name="SenseLineModeComboBox"
                                          ItemsSource="{Binding SenseLineModeOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          Style="{StaticResource InputComboBox}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource FieldBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[pilot_vent_to_atmosphere]}" Style="{StaticResource FieldLabel}" />
                                <CheckBox x:Name="VentToAtmosphereCheckBox"
                                          Content="{Binding VentCheckBoxLabel}"
                                          Style="{StaticResource InputCheckBox}"
                                          VerticalAlignment="Center"
                                          Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Background="{DynamicResource BrushInfoBannerBackground}">
                    <StackPanel>
                        <TextBlock Text="{Binding Loc[pilot_settings_note_title]}"
                                   Foreground="{DynamicResource BrushPrimary}"
                                   FontWeight="Bold"
                                   FontSize="18" />
                        <TextBlock Text="{Binding Loc[pilot_settings_note_body]}"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="StatusTextBlock"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource BrushSuccessText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,12,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="{Binding Loc[pilot_settings_apply]}"
                            Click="ApplyResult_Click"
                            Style="{StaticResource PrimaryActionButton}"
                            IsDefault="True" />
                    <Button Content="{Binding Loc[cancel]}"
                            Click="Cancel_Click"
                            Style="{StaticResource ActionButton}"
                            Margin="0" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
